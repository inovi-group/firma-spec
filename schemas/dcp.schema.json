{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://github.com/SAMTHP/firma-spec/schemas/dcp.schema.json",
  "title": "FIRMA Decision Context Packet",
  "description": "Structured data packet carrying decision context to a FIRMA ledger.",
  "type": "object",
  "required": ["dcp_id", "source_version", "firma_id_ref", "declared_intent", "observed_reality", "confidence_score", "actor_ids", "timestamp_utc", "signature"],
  "properties": {
    "dcp_id": { "type": "string", "format": "uuid" },
    "source_version": { "type": "string", "pattern": "^\\d+\\.\\d+\\.\\d+$" },
    "firma_id_ref": { "type": "string", "format": "uuid" },
    "context_vector": { "type": "array", "items": { "type": "number" }, "maxItems": 512 },
    "declared_intent": { "type": "object", "required": ["action"], "properties": { "action": { "type": "string" }, "parameters": { "type": "object" } } },
    "observed_reality": { "type": "object", "required": ["action"], "properties": { "action": { "type": "string" }, "parameters": { "type": "object" } } },
    "confidence_score": { "type": "number", "minimum": 0.0, "maximum": 1.0 },
    "actor_ids": { "type": "array", "items": { "type": "string", "format": "uuid" }, "minItems": 1 },
    "timestamp_utc": { "type": "string", "format": "date-time" },
    "signature": { "type": "string" },
    "metadata": { "type": "object" }
  },
  "additionalProperties": false
}
